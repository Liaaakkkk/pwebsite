<%- include('partials/header', { title: 'Buscar Receitas' }) %>

<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300..700&family=Quicksand:wght@300..700&display=swap" rel="stylesheet">

<style>
  body {
    background-image: url('/images/fundoo.png') !important;
    background-size: cover !important;
    background-position: top center !important;
    background-repeat: no-repeat !important;
    background-attachment: fixed !important;
    min-height: 100vh !important;
    margin: 0 !important;
    padding: 0 !important;
    font-family: 'fredoka', serif;
  }
  
  .hero {
    min-height: auto;
    padding-top: 90px;
  }

  .main-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60px 20px;
    box-sizing: border-box;
  }

  /* --- Balão Azul Escuro do Título --- */
  .titulo-balao {
    background-color: #d1425a;
    color: #f9ffd7;
    font-family: 'fredoka', serif;
    font-size: 45px;
    font-weight: bold;
    padding: 20px 60px;
    border-radius: 30px;
    margin-bottom: 40px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    max-width: 80vh;
  }

  /* --- Barra de Pesquisa --- */
  .search-container {
    display: flex;
    gap: 10px;
    width: 100%;
    max-width: 600px;
    margin-bottom: 40px;
  }

  .search-input {
    flex: 1;
    padding: 15px 20px;
    font-size: 18px;
    border: 2px solid #186f1b;
    border-radius: 30px;
    outline: none;
    font-family: 'fredoka', serif;
  }

  .btn-buscar {
    padding: 15px 30px;
    font-size: 18px;
    font-weight: bold;
    color: white;
    background-color: #186f1b;
    border: none;
    border-radius: 30px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-buscar:hover {
    background-color: #186f1b;
  }

  /* --- Grid de Resultados --- */
  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 30px;
    width: 100%;
    max-width: 1200px;
    margin-bottom: 40px;
  }

  .recipe-card {
    background: #f9ffd7;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s;
  }

  .recipe-card:hover {
    transform: translateY(-5px);
  }

  .recipe-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .recipe-card-content {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    text-align: center;
  }

  .recipe-card h3 {
    margin: 0 0 10px 0;
    color: #ff7643;
    font-size: 22px;
  }

  .recipe-card p {
    margin: 0 0 20px 0;
    color: #7f8c8d;
    font-size: 16px;
  }

  .btn-ver-mais {
    margin-top: auto;
    padding: 10px 20px;
    background-color: #d1425a;
    color: #f9ffd7;
    text-decoration: none;
    font-weight: bold;
    border-radius: 10px;
    transition: background 0.2s;
  }

  .btn-ver-mais:hover {
    background-color: #b33a4d;
  }

  /* Mensagens de status */
  .status-message {
    font-size: 20px;
    color: #2c3e50;
    font-weight: bold;
    text-align: center;
  }

  /* --- Botão Voltar --- */
  .btn-voltar {
    display: inline-block;
    padding: 12px 30px;
    border: none;
    border-radius: 8px;
    background-color: #186f1b;
    color: white;
    font-size: 16px;
    font-weight: bold;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
  }

  .btn-voltar:hover {
    background-color: #616a6b;
  }
</style>

<main class="main-content">

  <div class="titulo-balao">
    Buscar Receitas
  </div>

  <div class="search-container">
    <input type="text" id="search-input" class="search-input" placeholder="Digite um prato (ex: Chicken, Pasta)...">
    <button id="btn-buscar" class="btn-buscar">Buscar</button>
  </div>

  <div id="recipes-grid" class="recipes-grid">
    <p class="status-message">Digite algo acima para começar a explorar!</p>
  </div>

  <a href="/" class="btn-voltar">Voltar ao Início</a>

</main>

<script>
  const searchInput = document.getElementById('search-input');
  const btnBuscar = document.getElementById('btn-buscar');
  const recipesGrid = document.getElementById('recipes-grid');

  // 1. Função isolada para favoritar a receita no banco (Flashcards)
  async function favoritarReceita(id, nome, imagem) {
    try {
      const token = localStorage.getItem('token');

      const response = await fetch('/flashcards/salvar', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': token ? `Bearer ${token}` : ""
        },
        credentials: "include", // Envia os cookies da sessão caso o login use sessões
        body: JSON.stringify({ idReceita: id, nome: nome, imagem: imagem })
      });

      if (response.status === 401) {
        alert('Você precisa fazer login para salvar esta receita!');
        window.location.href = '/login';
        return;
      }

      const resultado = await response.json();

      if (resultado.sucesso) { 
        alert('Receita adicionada aos favoritos!');
      } else {
        alert(resultado.msg || 'Erro ao salvar receita.');
      }
    } catch (error) {
      console.error('Erro ao salvar:', error);
      alert('Erro de comunicação com o servidor.');
    }
  }

  // 2. Função isolada que faz a busca na API pública
  async function buscarReceitas() {
    const termo = searchInput.value.trim();
    
    if (!termo) {
      alert('Por favor, digite o nome de um prato ou ingrediente!');
      return;
    }

    // Mensagem de carregamento
    recipesGrid.innerHTML = '<p class="status-message">Buscando receitas deliciosas...</p>';

    try {
      // Faz a requisição para a API pública (TheMealDB)
      const response = await fetch(`https://www.themealdb.com/api/json/v1/1/search.php?s=${termo}`);
      const data = await response.json();

      // Limpa o grid para colocar os resultados
      recipesGrid.innerHTML = '';

      // Se não encontrar nenhuma receita
      if (!data.meals) {
        recipesGrid.innerHTML = '<p class="status-message">Nenhuma receita encontrada. Tente buscar em inglês (ex: Tomato, Beef, Cake)!</p>';
        return;
      }

      // Mapeia e renderiza os pratos encontrados
      data.meals.forEach(meal => {
        const card = document.createElement('div');
        card.className = 'recipe-card';
        
        // Sanitiza aspas simples no nome do prato para evitar quebras no onClick do botão
        const nomeFormatado = meal.strMeal.replace(/'/g, "\\'");
        
        card.innerHTML = `
          <img src="${meal.strMealThumb}" alt="${meal.strMeal}">
          <div class="recipe-card-content">
            <h3>${meal.strMeal}</h3>
            <p><strong>Categoria:</strong> ${meal.strCategory} | <strong>Origem:</strong> ${meal.strArea}</p>
            
            <button class="btn-salvar" onclick="favoritarReceita('${meal.idMeal}', '${nomeFormatado}', '${meal.strMealThumb}')" style="background: #2ecc71; color: white; border: none; padding: 10px; border-radius: 10px; margin-bottom: 10px; cursor: pointer; font-weight: bold; width: 100%;">
            Favoritar
            </button>

            <a href="${meal.strYoutube || '#'}" target="_blank" class="btn-ver-mais">
              ${meal.strYoutube ? 'Ver no YouTube' : 'Ver Detalhes'}
            </a>
          </div>
        `;
        
        recipesGrid.appendChild(card);
      });
    } catch (error) {
      console.error('Erro ao buscar receitas:', error);
      recipesGrid.innerHTML = '<p class="status-message" style="color: #e74c3c;">Ocorreu um erro ao carregar as receitas. Tente novamente.</p>';
    }
  }

  // 3. Escutadores de eventos (Clique no botão e tecla Enter)
  btnBuscar.addEventListener('click', buscarReceitas);
  searchInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      buscarReceitas();
    }
  });
</script>

<%- include('partials/footer') %>