<%- include('partials/header', { title: 'Login' }) %>

<link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@900&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300..700&family=Quicksand:wght@300..700&display=swap" rel="stylesheet">
  
  <style>
 body {
  background-image: url('/images/fundoo.png') !important;
  background-size: cover !important;
  background-position: top center !important;
  background-repeat: no-repeat !important;
  background-attachment: fixed !important;
  min-height: 100vh !important;
  margin: 0 !important;
  padding: 0 !important;
  font-family: 'fredoka', serif;
}
.hero {
    min-height: auto;
    padding-top: 90px;
}

h2 {
  font-size: 100px;
  color: #9d062c;
  text-align: center;
  font-family: 'fredoka', serif;
  font-weight: 1000;
  letter-spacing: 1px;
  margin-bottom: 80px;
}

.hero {
  padding-top: 80px;
  text-align: center;
}

/* Container do Formulário */
#loginForm {
  background: #fdfff1; 
  padding: 40px;
  border-radius: 25px;
  width: 100%;
  max-width: 400px; 
  margin: 30px auto 100px auto; 
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  gap: 20px;
  box-sizing: border-box;
}

/* Inputs de Email e Senha */
#loginForm input {
  width: 100%;
  padding: 15px;
  border: 1px solid #ccc;
  border-radius: 8px;
  font-size: 16px;
  box-sizing: border-box;
  transition: border-color 0.3s ease;
}

#loginForm input:focus {
  border-color: #186f1b;
  outline: none;
}

/* Botão Entrar */
#loginForm button {
  padding: 15px 25px;
  border: none;
  border-radius: 8px;
  color: white; 
  font-size: 18px;
  cursor: pointer;
  background-color: #186f1b;
  font-weight: bold;
  transition: background 0.2s ease;
}

#loginForm button:hover {
  background-color: #186f1b;
}

.form-footer {
  text-align: center;
  margin-top: 10px;
  font-size: 16px;
  color: #333;
  font-weight: bold;
}

.form-footer a {
  color: #007bff;
  text-decoration: none;
  transition: color 0.2s;
}

.form-footer a:hover {
  color: #0056b3;
  text-decoration: underline;
}
</style>

<section class="hero">
  <h2>Entrar na conta</h2>
</section>

<form id="loginForm">

  <input
    type="email"
    id="email"
    placeholder="Email"
    required
  />

  <input
    type="password"
    id="senha"
    placeholder="Senha"
    required
  />

  <button type="submit">
    Entrar
  </button>

  <div class="form-footer">
    Não tem uma conta? <a href="/signup">crie aqui!</a>
  </div>

</form>

<script>
document.getElementById("loginForm").addEventListener("submit", async (e) => {
    e.preventDefault();

    const email = document.getElementById("email").value;
    const senha = document.getElementById("senha").value;

    try {
        const resposta = await fetch("/auth/login", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ email, senha })
        });

        const data = await resposta.json();

        if (resposta.ok) {
            // ✔ só salva usuário
            localStorage.setItem("usuario", JSON.stringify(data.usuario));

            alert("Login realizado!");

            window.location.replace("/profile");
        } else {
            alert(data.msg || "Erro ao fazer login");
        }

    } catch (erro) {
        console.log(erro);
        alert("Erro ao fazer login");
    }
});
</script>

<%- include('partials/footer') -%>