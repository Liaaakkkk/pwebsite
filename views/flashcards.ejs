<%- include('partials/header', { title: 'Fixly :: Minhas Receitas Salvas' }) %>

<style>
 body {
  background-image: url('/images/fundoo.png') !important;
  background-size: cover !important;
  background-position: top center !important;
  background-repeat: no-repeat !important;
  background-attachment: fixed !important;
  min-height: 100vh !important;
  margin: 0 !important;
  padding: 0 !important;
  font-family: 'fredoka', serif;
}
.hero {
    min-height: auto;
    padding-top: 90px;
}

  .flashcard-main-container {
    max-width: 1100px;
    margin: 100px auto 120px auto;
    padding: 0 20px;
    box-sizing: border-box;
  }

  .titulo-balao {
    background-color: #d1425a;
    color: #f9ffd7;
    font-family: 'Merriweather', serif;
    font-size: 42px;
    font-weight: bold;
    padding: 20px 60px;
    border-radius: 30px;
    margin-bottom: 40px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  /* --- Grid de Receitas --- */
  .recipes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
    width: 100%;
    margin-bottom: 40px;
  }

  /* --- Card Adaptado do Estilo Flashcard --- */
  .recipe-flashcard {
    background: #f9ffd7;
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    border: 2px solid #f9ffd7;
  }

  .recipe-flashcard:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.12);
  }

  .recipe-header-tag {
    background-color: #ff7643;
    color: #581c00;
    font-weight: bold;
    font-size: 14px;
    padding: 8px 15px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .recipe-card-content {
    padding: 25px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-grow: 1;
  }

  .recipe-card-content h3 {
    margin: 0 0 15px 0;
    color: #d1425a;
    font-size: 22px;
  }

  /* Imagem com efeito de revelação */
  .recipe-image-wrapper {
    display: none; /* Escondido por padrão, simulando o verso do card */
    width: 100%;
    margin-top: 15px;
    padding-top: 15px;
    border-top: 2px dashed #f9ffd7;
  }

  .recipe-image-wrapper img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 15px;
  }

  .clique-revelar-aviso {
    font-size: 13px;
    color: #d1425a;
    font-weight: bold;
    margin-top: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* --- Botão Voltar --- */
  .btn-voltar-container {
    text-align: center;
    margin-top: 20px;
  }

  .btn-voltar-fixly {
    display: inline-block;
    background-color: #d1425a;
    color: #f9ffd7;
    font-size: 18px;
    font-weight: bold;
    border: none;
    border-radius: 12px;
    padding: 14px 40px;
    text-decoration: none;
    transition: background 0.2s;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .btn-voltar-fixly:hover {
    background-color: #d1425a;
  }

  .status-message {
    font-size: 20px;
    color: #2c3e50;
    font-weight: bold;
    text-align: center;
    grid-column: 1 / -1;
    padding: 40px;
  }
</style>

<div class="flashcard-main-container">

  <div class="titulo-balao">
    Minhas Receitas Salvas
  </div>

  <div class="recipes-grid">
    <% if (typeof receitas === 'undefined' || receitas.length === 0) { %>
      <p class="status-message">Você ainda não possui nenhuma receita favoritada em seus flashcards.</p>
    <% } else { %>
      <% receitas.forEach(function(recipe, idx) { %>
        <div class="recipe-flashcard" onclick="revelarReceita('<%= idx %>')">
          <div class="recipe-header-tag">
            <%= recipe.materia || "Receitas" %>
          </div>
          
          <div class="recipe-card-content">
            <h3><%= recipe.pergunta %></h3>
            
            <span class="clique-revelar-aviso" id="aviso-<%= idx %>">👉 Clique para revelar a foto</span>
            
            <div id="foto-<%= idx %>" class="recipe-image-wrapper">
              <img src="<%= recipe.resposta %>" alt="<%= recipe.pergunta %>">
            </div>
          </div>
        </div>
      <% }); %>
    <% } %>
  </div>

  <div class="btn-voltar-container">
    <a href="/" class="btn-voltar-fixly">Voltar ao Início</a>
  </div>

</div>

<script>
  // Função interativa clássica de virar o card/mostrar conteúdo oculto
  function revelarReceita(index) {
    const elementoFoto = document.getElementById(`foto-${index}`);
    const elementoAviso = document.getElementById(`aviso-${index}`);

    if (elementoFoto.style.display === "block") {
      elementoFoto.style.display = "none";
      elementoAviso.style.display = "block";
      elementoAviso.textContent = "👉 Clique para revelar a foto";
    } else {
      elementoFoto.style.display = "block";
      elementoAviso.style.display = "block";
      elementoAviso.textContent = "👆 Clique para ocultar";
    }
  }
</script>

<%- include('partials/footer') %>